DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/news_ai
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=dev

# Optional auth
# API_KEY=change_me

# Managed LLM (OpenAI-compatible)
# OPENAI_API_KEY=change_me
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_SUMMARIZE=gpt-4o-mini
# OPENAI_MODEL_CLASSIFY=gpt-4o-mini
# OPENAI_MODEL_EMBED=text-embedding-3-small

# Hugging Face Inference API (sentiment)
# HF_INFERENCE_API_KEY=change_me
# HF_SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# Waitlist / Coming Soon (generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# WAITLIST_FERNET_KEY=
# WAITLIST_HMAC_SECRET=long-random-secret-for-email-fingerprinting

# Live headlines (NewsAPI — register at https://newsapi.org/)
# NEWS_API_KEY=
# NEWS_API_COUNTRY=us
# API_CACHE_CONTROL_SECONDS=60

# RSS poller
# RSS_FEEDS=https://example.com/rss.xml,https://example.org/feed
# RSS_SOURCE_NAME=ExampleNews
# RSS_MAX_ENTRIES=25

